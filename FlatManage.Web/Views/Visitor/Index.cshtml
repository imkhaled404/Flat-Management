@{
    ViewData["Title"] = "Visitor Records";
}

<div class="card border-0 mb-4">
    <div class="card-body p-4 bg-primary text-white rounded-3">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 class="fw-bold">Security Gate Management</h4>
                <p class="mb-0 opacity-75">Tracking entry and exit for Skyline Residency.</p>
            </div>
            <div class="col-md-4 text-end">
                <button class="btn btn-light rounded-pill px-4">
                    <i class="fas fa-user-plus me-1"></i> Check-in Visitor
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-3">Visitor Info</th>
                    <th>To Unit</th>
                    <th>Purpose</th>
                    <th>Vehicle</th>
                    <th>In Time</th>
                    <th>Out Time</th>
                    <th class="text-end pe-3">Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="ps-3">
                        <div class="fw-bold">Rahim Uddin</div>
                        <small class="text-muted">01900112233</small>
                    </td>
                    <td><span class="badge bg-secondary">Unit 401</span></td>
                    <td>Delivery</td>
                    <td><small>DHA-Metro-1234</small></td>
                    <td>10:30 AM</td>
                    <td><span class="badge bg-success-subtle text-success">Checked Out</span></td>
                    <td class="text-end pe-3">
                        <button class="btn btn-sm btn-light border"><i class="fas fa-info-circle"></i></button>
                    </td>
                </tr>
                <tr>
                    <td class="ps-3">
                        <div class="fw-bold">Anisur Rahman</div>
                        <small class="text-muted">01701010101</small>
                    </td>
                    <td><span class="badge bg-secondary">Unit 205</span></td>
                    <td>Guest</td>
                    <td><small>N/A</small></td>
                    <td>12:15 PM</td>
                    <td><button class="btn btn-sm btn-danger rounded-pill px-3">Check Out</button></td>
                    <td class="text-end pe-3">
                        <button class="btn btn-sm btn-light border"><i class="fas fa-info-circle"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
