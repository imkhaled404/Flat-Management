@{
    ViewData["Title"] = "Tenant Management";
}

<div class="card border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold">Active Tenants</h5>
        <button class="btn btn-primary btn-sm rounded-pill px-3">
            <i class="fas fa-plus me-1"></i> Add New Tenant
        </button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-3">Name</th>
                        <th>Unit</th>
                        <th>Contact</th>
                        <th>Status</th>
                        <th>Joined</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-3">
                            <div class="d-flex align-items-center">
                                <img src="https://ui-avatars.com/api/?name=James+Wilson&background=random" class="rounded-circle me-2" width="32">
                                <div>
                                    <div class="fw-bold">James Wilson</div>
                                    <small class="text-muted">NID: 1234567890</small>
                                </div>
                            </div>
                        </td>
                        <td><span class="badge bg-info-subtle text-info px-2">Unit 302</span></td>
                        <td>
                            <div>01711223344</div>
                            <small class="text-muted">james@example.com</small>
                        </td>
                        <td><span class="badge bg-success">Active</span></td>
                        <td>Jan 12, 2026</td>
                        <td class="text-end pe-3">
                            <button class="btn btn-sm btn-light border"><i class="fas fa-eye"></i></button>
                            <button class="btn btn-sm btn-light border"><i class="fas fa-edit"></i></button>
                        </td>
                    </tr>
                    <!-- More mock rows -->
                </tbody>
            </table>
        </div>
    </div>
</div>
